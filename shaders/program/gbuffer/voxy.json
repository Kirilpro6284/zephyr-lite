{
  "unusedString":
    "
        #include "/include/main.glsl"
    ",
  "version": 1,
  "uniforms": [
    "taa_offset",
    "taa_offset_prev",
    "internalTexelSize",
    "internalScreenSize",
    "screenSize",
    "frameCounter",
    "frameTimeCounter",
    "eyeBrightnessSmooth",
    "cameraPositionFract",
    "cameraPosition",
    "shadowDir",
    "moonDir",
    "sunDir",
    "shadowLightBrightness",
    "near",
    "viewDistance",
    "gbufferProjScale",
    "gbufferProjScaleInv",
    "gbufferProjScalePrev",
    "gbufferProjScalePrevInv",
    "gbufferModelView",
    "gbufferModelViewInverse",
    "gbufferPreviousModelView",
    "shadowModelView",
    "vxProjInv"
  ],
  "samplers": {
    "scattering": "sampler2D",
    "transmittance" : "sampler2D",
    "skyIrradianceTex" : "sampler2D",
    "shadowtex1HW": "sampler2DShadow",
    "shadowtex0": "sampler2D",
    "shadowtex1": "sampler2D",
    "shadowcolor0": "sampler2D",
    "shadowcolor1": "sampler2D",
  #ifdef COLORED_LIGHTING
    "lightSampler": "sampler3D",
    "voxelSampler": "usampler3D",
  #endif
    "lodDepthTex1": "sampler2D",
    "colortex7": "sampler2D",
    "colortex6": "sampler2D",
    "depthtex1": "sampler2D"
  },
  "taaOffset": "{return taa_offset;}",
  "useViewportDims": true,
  "excludeLodsFromVanillaDepth": true,
  "renderScale": [taauRenderScale, taauRenderScale],
  "opaqueDrawBuffers": [9],
  "translucentDrawBuffers": [16, 8]
}